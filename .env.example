# =============================================================================
# TransTTS — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local dev (SQLite — works out of the box):
DATABASE_URL="file:./dev.db"

# Production (Vercel / serverless) — use Postgres. Examples:
#   Vercel Postgres:  DATABASE_URL="postgres://..."
#   Supabase:         DATABASE_URL="postgresql://...?pgbouncer=true"
#   Neon:             DATABASE_URL="postgres://...?sslmode=require"
#
# When switching to Postgres, also change `provider` to `postgresql` in
# prisma/schema.prisma and re-run `npx prisma migrate dev --name init`.

# -----------------------------------------------------------------------------
# Razorpay (https://dashboard.razorpay.com/app/keys)
# -----------------------------------------------------------------------------
# Server-side (NEVER expose to the browser):
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Client-side (safe to expose; same value as RAZORPAY_KEY_ID):
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Webhook secret (set in Razorpay dashboard → Webhooks → Add new webhook):
RAZORPAY_WEBHOOK_SECRET=any_long_random_string_you_set_in_dashboard

# -----------------------------------------------------------------------------
# AI providers (used by transcription/translation routes)
# -----------------------------------------------------------------------------
# Free tier — Groq Whisper (https://console.groq.com)
GROQ_API_KEY=

# Optional — paid OpenAI Whisper fallback (https://platform.openai.com)
OPENAI_API_KEY=
