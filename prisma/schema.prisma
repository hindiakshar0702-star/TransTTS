generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Job {
  id         String   @id @default(uuid())
  type       String   // "transcribe" | "translate" | "tts"
  title      String
  status     String   @default("processing") // "processing" | "completed" | "error"
  progress   Int      @default(0)

  // Transcription fields
  fileName   String?
  fileSize   Int?
  language   String?
  duration   Float?
  transcript String?
  segments   String?  // JSON string

  // Translation fields
  sourceText     String?
  translatedText String?
  sourceLang     String?
  targetLang     String?
  engine         String?

  // TTS fields
  text       String?
  voice      String?
  audioUrl   String?

  errorMsg   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
