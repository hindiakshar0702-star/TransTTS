generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Job {
  id         String   @id @default(uuid())
  type       String   // "transcribe" | "translate" | "tts"
  title      String
  status     String   @default("processing") // "processing" | "completed" | "error"
  progress   Int      @default(0)

  // Transcription fields
  fileName   String?
  fileSize   Int?
  language   String?
  duration   Float?
  transcript String?
  segments   String?  // JSON string

  // Translation fields
  sourceText     String?
  translatedText String?
  sourceLang     String?
  targetLang     String?
  engine         String?

  // TTS fields
  text       String?
  voice      String?
  audioUrl   String?

  errorMsg   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Order {
  id                String   @id @default(uuid())
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  razorpaySignature String?

  plan              String   // "starter" | "pro" | "enterprise"
  cycle             String   // "monthly" | "yearly"
  amount            Int      // in paise (₹1 = 100 paise)
  currency          String   @default("INR")
  status            String   @default("created") // "created" | "paid" | "failed" | "refunded"

  userEmail         String?
  userName          String?

  // Subscription validity (set when paid)
  validUntil        DateTime?

  // Razorpay webhook payloads (raw JSON for audit)
  webhookEvent      String?
  errorMsg          String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userEmail])
  @@index([status])
}
